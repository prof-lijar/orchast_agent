# Product repository (GitHub slug)
PRODUCT_REPO=user/my-nextjs-app

# Local path where the product repo is cloned
PRODUCT_REPO_DIR=/path/to/product-repo

# Default branch for the product repo
DEFAULT_BRANCH=main

# LLM model (Ollama)
AGENT_MODEL=gemma3:27b

# Cycle timing
CYCLE_INTERVAL=0
AGENT_TIMEOUT=1800

# Context window
NUM_CTX=32768
