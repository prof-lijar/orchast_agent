# Product repository (GitHub slug)
PRODUCT_REPO=user/my-app

# Local path where the product repo is cloned
PRODUCT_REPO_DIR=/path/to/product-repo

# Default branch for the product repo
DEFAULT_BRANCH=main

# LLM model (Ollama)
AGENT_MODEL=gemma4:31b

# Cycle timing
CYCLE_INTERVAL=0
AGENT_TIMEOUT=1800

# Context window
NUM_CTX=32768

# Skills directory (default: ./skills)
# SKILLS_DIR=/path/to/skills

# Trusted skill sources (comma-separated URL prefixes for install_skill)
# Only skills from these URLs can be installed at runtime
# TRUSTED_SKILL_SOURCES=https://raw.githubusercontent.com/myorg/skills/main/,https://skills.example.com/
